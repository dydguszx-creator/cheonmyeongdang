{
  "functions": {
    "api/analyze.js": {
      "maxDuration": 300
    }
  },
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/saju", "dest": "/saju.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
